-- [6] HÀM BAY TWEEN TỐC ĐỘ CHUẨN 300
function TweenTo(targetCFrame)
    local char = game.Players.LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    local distance = (targetCFrame.Position - char.HumanoidRootPart.Position).Magnitude
    local speed = 300 
    local tweenInfo = TweenInfo.new(distance / speed, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(char.HumanoidRootPart, tweenInfo, {CFrame = targetCFrame})
    
    tween:Play()
    
    local completed = false
    local connection
    connection = tween.Completed:Connect(function()
        completed = true
        if connection then connection:Disconnect() end
    end)
    
    local timeout = (distance / speed) + 0.2
    local start = os.clock()
    while not completed and (os.clock() - start) < timeout do
        if _G.PauseHop then tween:Cancel(); break end 
        task.wait()
    end
    
    if not completed then
        tween:Cancel()
        if connection then connection:Disconnect() end
    end
end

-- [7] LUỒNG TÌM VÀ GOM RƯƠNG CHUẨN KHÔNG LỖI BỘ NHỚ
spawn(function()
    while true do
        task.wait(0.05)
        if _G.AutoChest and not _G.PauseHop then
            pcall(function()
                local lp = game.Players.LocalPlayer
                local char = lp.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    
                    local closest = nil
                    local dist = 999999 
                    
                    -- Cách quét mới nhắm trực tiếp vào Workspace gốc chống sót vật thể
                    local children = game.Workspace:GetChildren()
                    for i = 1, #children do
                        local v = children[i]
                        if (string.find(v.Name, "Chest") or string.find(v.Name, "Box")) and v:IsA("Part") then
                            local mag = (v.Position - char.HumanoidRootPart.Position).Magnitude
                            if mag < dist then
                                dist = mag
                                closest = v
                            end
                        end
                    end
                    
                    -- Nếu không tìm thấy ở Workspace ngoài, lướt nhanh thư mục con
                    if not closest then
                        for _, v in pairs(game.Workspace:GetDescendants()) do
                            if v:IsA("Part") and (string.find(v.Name, "Chest") or string.find(v.Name, "Box")) then
                                if v:FindFirstChild("TouchInterest") then
                                    local mag = (v.Position - char.HumanoidRootPart.Position).Magnitude
                                    if mag < dist then
                                        dist = mag
                                        closest = v
                                    end
                                end
                            end
                        end
                    end
                    
                    -- Thực hiện di chuyển nhặt rương
                    if closest then
                        _G.ForceHopNow = false
                        StatusLabel.Text = "Trạng thái: ✈️ Nhặt rương tốc độ 300..."
                        StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
                        
                        TweenTo(closest.CFrame)
                        
                        if (char.HumanoidRootPart.Position - closest.Position).Magnitude < 25 then
                            firetouchinterest(char.HumanoidRootPart, closest, 0)
                            task.wait(0.02)
                            firetouchinterest(char.HumanoidRootPart, closest, 1)
                            
                            StatusLabel.Text = "Trạng thái: ⏱️ Delay lượm rương (1s)..."
                            StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
                            task.wait(1) 
                            
                            pcall(function() closest:Destroy() end)
                            timeSpent = 0 -- Reset bộ đếm thời gian vì vừa nhặt được rương thành công
                        end
                    else
                        _G.ForceHopNow = true 
                    end
                end
            end)
        end
    end
end)

-- [8] THUẬT TOÁN HOP SERVER RANDOM + BỘ ĐẾM ÉP BUỘC HOP KHI BỊ TREO
function PublicServerHop()
    StatusLabel.Text = "Trạng thái: 🚀 ĐANG TÌM SERVER MỚI..."
    StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 0)
    local lp = game.Players.LocalPlayer
    pcall(function()
        local rawData = game:HttpGet("https://games.roblox.com/v1/games/" .. currentPlaceId .. "/servers/Public?sortOrder=Desc&limit=100")
        local servers = HttpService:JSONDecode(rawData)
        
        local serverList = servers.data
        for i = #serverList, 2, -1 do
            local j = math.random(i)
            serverList[i], serverList[j] = serverList[j], serverList[i]
        end
        
        for _, server in pairs(serverList) do
            if server.playing and server.playing < server.maxPlayers and server.id ~= game.JobId then
                local isOldServer = false
                for _, oldId in pairs(_G.VisitedServers) do
                    if server.id == oldId then isOldServer = true break end
                end
                if not isOldServer then
                    table.insert(_G.VisitedServers, server.id) 
                    task.wait(0.5)
                    TeleportService:TeleportToPlaceInstance(currentPlaceId, server.id, lp)
                    return
                end
            end
        end
    end)
end

