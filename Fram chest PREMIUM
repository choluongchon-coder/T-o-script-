-- Hàm đếm số lượng Bột Cacao trong túi đồ
function GetCocoaCount()
    local count = 0
    pcall(function()
        local inventory = game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("getInventory")
        for _, item in pairs(inventory) do
            if item.Name == "Conjured Cocoa" then
                count = item.Count
            end
        end
    end)
    return count
end

-- Hàm lấy số lượng quái còn lại để gọi Katakuri V2 từ NPC Drip Mama
