-- [2] HÀM TWEEN CHUẨN (TỐC ĐỘ 300)
function TweenTo(pos)
    local char = game.Players.LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local dist = (pos.Position - char.HumanoidRootPart.Position).Magnitude
    local tween = TweenService:Create(char.HumanoidRootPart, TweenInfo.new(dist / 300, Enum.EasingStyle.Linear), {CFrame = pos})
    tween:Play()
    tween.Completed:Wait()
end

-- [3] LUỒNG QUÉT RƯƠNG VÀ ĐẾM NGƯỢC 40S
spawn(function()
    while true do
        task.wait(0.1)
        if _G.AutoChest and not _G.PauseHop then
            local lp = game.Players.LocalPlayer
            local char = lp.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local closest = nil
                local dist = math.huge
                
                -- Quét tìm rương
                for _, v in pairs(game.Workspace:GetDescendants()) do
                    if v:IsA("Part") and (string.find(v.Name, "Chest") or string.find(v.Name, "Box")) then
                        if v:FindFirstChild("TouchInterest") then
                            local mag = (v.Position - char.HumanoidRootPart.Position).Magnitude
                            if mag < dist then dist = mag; closest = v end
                        end
                    end
                end

                if closest then
                    timeSpent = 0 -- Reset timer nếu tìm thấy rương
                    StatusLabel.Text = "Trạng thái: Đang bay tới rương..."
                    TweenTo(closest.CFrame)
                    firetouchinterest(char.HumanoidRootPart, closest, 0)
                    firetouchinterest(char.HumanoidRootPart, closest, 1)
                    task.wait(0.5)
                else
                    timeSpent = timeSpent + 0.1
                    StatusLabel.Text = "Trạng thái: Không thấy rương, đang chờ..."
                end
                TimerLabel.Text = "Thời gian đếm ngược: " .. math.floor(timeSpent) .. "s / 40s"
            end
        end
    end
end)

-- [4] ÉP BUỘC HOP SERVER KHI ĐỦ 40S
spawn(function()
    while true do
        task.wait(1)
        if timeSpent >= 40 then
            StatusLabel.Text = "Trạng thái: Hết thời gian, đang Hop..."
            local rawData = game:HttpGet("https://games.roblox.com/v1/games/" .. currentPlaceId .. "/servers/Public?sortOrder=Desc&limit=100")
            local servers = HttpService:JSONDecode(rawData)
            for _, server in pairs(servers.data) do
                if server.id ~= game.JobId then
                    TeleportService:TeleportToPlaceInstance(currentPlaceId, server.id, game.Players.LocalPlayer)
                    break
                end
            end
            timeSpent = 0
        end
    end
end)
