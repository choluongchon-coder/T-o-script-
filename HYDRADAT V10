-- [6] THUẬT TOÁN HOP SERVER RANDOM FIX CỨNG ĐÚNG 40 GIÂY
function PublicServerHop()
    StatusLabel.Text = "Trạng thái: 🚀 ĐANG TÌM PHÒNG MỚI..."
    StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 0)
    pcall(function()
        local rawData = game:HttpGet("https://games.roblox.com/v1/games/" .. currentPlaceId .. "/servers/Public?sortOrder=Desc&limit=100")
        local servers = HttpService:JSONDecode(rawData)
        
        local serverList = servers.data
        for i = #serverList, 2, -1 do
            local j = math.random(i)
            serverList[i], serverList[j] = serverList[j], serverList[i]
        end
        
        for _, server in pairs(serverList) do
            if server.playing and server.playing < server.maxPlayers and server.id ~= game.JobId then
                local isOldServer = false
                for _, oldId in pairs(_G.VisitedServers) do
                    if server.id == oldId then isOldServer = true break end
                end
                if not isOldServer then
                    table.insert(_G.VisitedServers, server.id) 
                    task.wait(0.5)
                    TeleportService:TeleportToPlaceInstance(currentPlaceId, server.id, game.Players.LocalPlayer)
                    return
                end
            end
        end
    end)
end

