-- ==========================================
-- THUẬT TOÁN ĐỔI SERVER CHỐNG LẶP PHÒNG CŨ
-- ==========================================
function PublicServerHop()
    StatusLabel.Text = "🚀 ĐANG LỌC SERVER MỚI KHÔNG TRÙNG..."
    StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
    local HttpService = game:GetService("HttpService")
    local TeleportService = game:GetService("TeleportService")
    local PlaceId = game.PlaceId
    
    pcall(function()
        local rawData = game:HttpGet("https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Asc&limit=100")
        local servers = HttpService:JSONDecode(rawData)
        
        for _, server in pairs(servers.data) do
            if server.playing < server.maxPlayers and server.id ~= game.JobId then
                local isOldServer = false
                for _, oldId in pairs(_G.VisitedServers) do
                    if server.id == oldId then
                        isOldServer = true
                        break
                    end
                end
                
                if not isOldServer then
                    table.insert(_G.VisitedServers, server.id) 
                    TeleportService:TeleportToPlaceInstance(PlaceId, server.id, game.Players.LocalPlayer)
                    return
                end
            end
        end
    end)
end

-- ==========================================
-- HÀM DI CHUYỂN TWEEN TO CÓ CHỐNG KẸT ĐỨNG IM
-- ==========================================
local TweenService = game:GetService("TweenService")
function TweenTo(targetCFrame)
    local char = game.Players.LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    if char.HumanoidRootPart.Anchored then char.HumanoidRootPart.Anchored = false end
    
    local distance = (targetCFrame.Position - char.HumanoidRootPart.Position).Magnitude
    local speed = 360 
    local tweenInfo = TweenInfo.new(distance / speed, Enum.EasingStyle.Linear)
    
    local tween = TweenService:Create(char.HumanoidRootPart, tweenInfo, {CFrame = targetCFrame})
    tween:Play()
    
    local completed = false
    local connection
    connection = tween.Completed:Connect(function()
        completed = true
        if connection then connection:Disconnect() end
    end)
    
    -- Chống kẹt đứng im: Nếu quá thời gian di chuyển + 0.4s bảo vệ mà chưa tới, ép hủy để đi tiếp
    local timeout = (distance / speed) + 0.4
    local start = os.clock()
    while not completed and (os.clock() - start) < timeout do
        task.wait()
    end
    
    if not completed then
        tween:Cancel()
        if connection then connection:Disconnect() end
    end
end

function EquipWeapon()
    local lp = game.Players.LocalPlayer
    for _, tool in pairs(lp.Backpack:GetChildren()) do
        if tool:IsA("Tool") and (tool.ToolTip == "Melee" or tool.ToolTip == "Sword") then
            lp.Character.Humanoid:EquipTool(tool)
            break
        end
    end
end

function SetAntiGravity(char)
    if not char.HumanoidRootPart:FindFirstChild("BodyVelocity") then
        local bv = Instance.new("BodyVelocity")
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        bv.Parent = char.HumanoidRootPart
    end
    char.HumanoidRootPart.CanCollide = false
    char.Humanoid.PlatformStand = true
end

