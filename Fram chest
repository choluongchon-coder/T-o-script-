-- ==========================================
-- THUẬT TOÁN QUÉT RƯƠNG TOÀN DIỆN CHO CẢ SEA 1, SEA 2, SEA 3
-- ==========================================
spawn(function()
    while true do
        task.wait(0.1) -- Đẩy tốc độ quét lên mức tối đa
        if _G.AutoChest and not _G.PauseHop then
            pcall(function()
                local lp = game.Players.LocalPlayer
                local char = lp.Character
                if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChildOfClass("Humanoid") then
                    
                    local chestTable = {}
                    
                    -- Sử dụng GetDescendants quét sâu toàn bộ cấu trúc map để tránh sót rương ở đảo xa (Đặc biệt là Sea 3)
                    for _, v in pairs(game.Workspace:GetDescendants()) do
                        if v:IsA("Part") and (string.find(v.Name, "Chest") or string.find(v.Name, "Box")) then
                            table.insert(chestTable, v)
                        end
                    end
                    
                    -- Sắp xếp rương theo khoảng cách từ gần đến xa
                    table.sort(chestTable, function(a, b)
                        return (a.Position - char.HumanoidRootPart.Position).Magnitude < (b.Position - char.HumanoidRootPart.Position).Magnitude
                    end)
                    
                    if #chestTable > 0 then
                        _G.ForceHopNow = false 
                        StatusLabel.Text = "Trạng thái: Đang nhặt rương (".. #chestTable .." cái trên map)..."
                        StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
                        
                        local targetChest = chestTable[1]
                        if targetChest and targetChest.Parent then
                            SetAntiGravity(char)
                            TweenTo(targetChest.CFrame)
                            
                            -- Giả lập chạm nhặt rương siêu tốc và xóa rương cục bộ ngay lập tức để tránh khựng vị trí
                            if (char.HumanoidRootPart.Position - targetChest.Position).Magnitude < 7 then
                                firetouchinterest(char.HumanoidRootPart, targetChest, 0)
                                task.wait(0.01)
                                firetouchinterest(char.HumanoidRootPart, targetChest, 1)
                                targetChest:Destroy() 
                            end
                        end
                    else
                        -- Không còn rương nào trên toàn bộ Workspace => Kích hoạt đổi Server ngay
                        _G.ForceHopNow = true
                        StatusLabel.Text = "Trạng thái: Đã hết sạch rương! Đang ép nhảy SV..."
                        StatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
                        char.Humanoid.PlatformStand = false
                        if char.HumanoidRootPart:FindFirstChild("BodyVelocity") then
                            char.HumanoidRootPart.BodyVelocity:Destroy()
                        end
                    end
                end
            end)
        else
            -- Giải phóng trạng thái nhân vật khi đang dừng nhặt rương làm event boss
            pcall(function()
                local char = game.Players.LocalPlayer.Character
                if char and char:FindFirstChild("Humanoid") and _G.PauseHop then
                    char.HumanoidRootPart.CanCollide = true
                end
            end)
        end
    end
end)

